rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: rooms
    // Fields:
    //   - number: string (required)
    //   - type: string (single/double)
    //   - status: string (available/occupied/maintenance)
    //   - price: number
    //   - lastElectricityMeter: number
    //   - paymentStatus: string (paid/unpaid/debt)
    //   - currentGuestId: string (optional)
    //   - facilities: list (optional)
    //
    // Collection: guests
    // Fields:
    //   - name: string (required)
    //   - idNumber: string (required)
    //   - phone: string
    //   - email: string
    //   - idPhoto: string
    //   - checkInDate: string
    //
    // Collection: facilities
    // Fields:
    //   - name: string (required)
    //   - compensationPrice: number
    //
    // Collection: invoices
    // Fields:
    //   - roomId: string (required)
    //   - month: number
    //   - year: number
    //   - electricityOld: number
    //   - electricityNew: number
    //   - electricityUsed: number
    //   - electricityPrice: number
    //   - waterPrice: number
    //   - extraServices: list of maps
    //   - totalPrice: number
    //   - status: string (paid/unpaid)
    //   - createdAt: timestamp/string
    //
    // Collection: roomServiceUsages
    // Fields:
    //   - roomId: string (required)
    //   - month: string (YYYY-MM format)
    //   - services: list of maps {
    //       serviceId: string
    //       quantity: number
    //       createdAt: string
    //       notes: string (optional)
    //     }
    //   - createdAt: timestamp
    //   - updatedAt: timestamp
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/superAdmins/$(request.auth.token.email));
    }

    function isWhitelisted() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.token.email));
    }

    // Domain Validators
    function isValidRoom(data) {
      return data.number is string && data.number.size() > 0 && data.number.size() < 20 &&
             data.type in ['single', 'double'] &&
             data.status in ['available', 'occupied', 'maintenance'] &&
             data.price is number && data.price >= 0 &&
             data.lastElectricityMeter is number &&
             data.paymentStatus in ['paid', 'unpaid', 'debt'];
    }

    function isValidGuest(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.idNumber is string && data.idNumber.size() > 0 && data.idNumber.size() < 50;
    }

    function isValidFacility(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.compensationPrice is number && data.compensationPrice >= 0;
    }

    function isValidInvoice(data) {
      return data.roomId is string &&
             data.month is number && data.month >= 1 && data.month <= 12 &&
             data.year is number &&
             data.totalPrice is number && data.totalPrice >= 0 &&
             data.status in ['paid', 'unpaid'];
    }

    function isValidExtraService(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.category in ['laundry', 'cleaning', 'amenities', 'parking', 'food', 'other'] &&
             data.isActive is bool;
    }

    function isValidUtilityPricing(data) {
      return data.water.pricePerPerson is number && data.water.pricePerPerson >= 0 &&
             data.electricity.pricePerKwh is number && data.electricity.pricePerKwh >= 0 &&
             data.effectiveDate is string;
    }

    function isValidRoomServiceUsage(data) {
      return data.roomId is string && data.roomId.size() > 0 &&
             data.month is string && data.month.matches('^[0-9]{4}-[0-9]{2}$') &&
             data.services is list &&
             data.services.size() >= 0;
    }

    function isValidSmartLock(data) {
      return data.roomId is string && data.roomId.size() > 0 &&
             data.password is string && data.password.size() > 0 &&
             data.passwordExpiryDate is string &&
             data.nextBatteryReplacementDate is string;
    }

    // Rules
    match /rooms/{roomId} {
      allow read: if isAuthenticated();
      allow create, update: if isWhitelisted() && isValidRoom(request.resource.data);
      allow delete: if isWhitelisted();
    }

    match /guests/{guestId} {
      allow read: if isAuthenticated();
      allow create, update: if isWhitelisted() && isValidGuest(request.resource.data);
      allow delete: if isWhitelisted();
    }

    match /facilities/{facilityId} {
      allow read: if isAuthenticated();
      allow create, update: if isWhitelisted() && isValidFacility(request.resource.data);
      allow delete: if isWhitelisted();
    }

    match /invoices/{invoiceId} {
      allow read: if isAuthenticated();
      allow create, update: if isWhitelisted() && isValidInvoice(request.resource.data);
      allow delete: if isWhitelisted();
    }

    match /users/{userEmail} {
      // Users can read their own document (email is the document ID)
      allow read: if isSuperAdmin() || request.auth.token.email == userEmail;
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    match /extraServices/{serviceId} {
      allow read: if isAuthenticated();
      allow create, update: if isWhitelisted() && isValidExtraService(request.resource.data);
      allow delete: if isWhitelisted();
    }

    match /utilityPricing/{pricingId} {
      allow read: if isAuthenticated();
      // All authenticated users can manage pricing (managers need this for daily operations)
      allow create, update: if isAuthenticated() && isValidUtilityPricing(request.resource.data);
      allow delete: if isWhitelisted();
    }

    match /roomServiceUsages/{usageId} {
      allow read: if isAuthenticated();
      allow create, update: if isWhitelisted() && isValidRoomServiceUsage(request.resource.data);
      allow delete: if isWhitelisted();
    }

    match /smartLocks/{lockId} {
      allow read: if isAuthenticated();
      allow create, update: if isWhitelisted() && isValidSmartLock(request.resource.data);
      allow delete: if isWhitelisted();
    }

    match /userActivities/{activityId} {
      allow read: if isSuperAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isSuperAdmin();
    }

    match /superAdmins/{email} {
      allow read: if isSuperAdmin();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }
  }
}
